@{
    ViewData["Title"] = "Home Page";
}

<section class="Contenedor">
    <h1>Felicidades, has obtenido:</h1>
    <div class="Figuritas">
        @foreach (var j in ViewBag.jugadores){
            <div>
                <img src="~/images/jugadores/@(j.nombre.ToLower()).svg">
            </div>
        }
    </div>
    <div class= "Navegador">
        <form action="@Url.Action("AbrirSobre", "Home")">
            <button type="submit">Abrir otro sobre</button>
        </form>
        <form action="@Url.Action("Index", "Home")">
            <button type="submit">Menú principal</button>
        </form> 
        <form action="@Url.Action("Album", "Home")">
            <button type="submit">Álbum</button>
        </form>
    </div>
</section>
